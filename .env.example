# GOOGLE_CREDENTIALS_JSON
# Full JSON body of the Google credentials (service account or OAuth)
# used for Drive and Sheets API.
# Example value (replace with your real JSON; keep it one line in `.env`):
GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key":"YOUR_PRIVATE_KEY","client_email":"YOUR_CLIENT_EMAIL"}'

# LOGGING_LEVEL
# Log level for the application (e.g. DEBUG, INFO, WARNING).
# Example:
LOGGING_LEVEL=INFO

# CSV_SOURCE_FOLDER_ID
# Google Drive folder ID of the “drop zone” where CSV and other files are placed for processing.
# Example:
CSV_SOURCE_FOLDER_ID=YOUR_CSV_SOURCE_FOLDER_ID

# DJ_SETS_FOLDER_ID
# Google Drive folder ID of the main DJ Sets folder that contains year subfolders and the Summary subfolder.
# Example:
DJ_SETS_FOLDER_ID=YOUR_DJ_SETS_FOLDER_ID

# OUTPUT_NAME
# Name of the master “DJ Set Collection” Google Sheet.
# Example:
OUTPUT_NAME="DJ Set Collection"

# TEMP_TAB_NAME
# Name of the temporary tab used while building the collection spreadsheet.
# Example:
TEMP_TAB_NAME="Temp"

# SUMMARY_TAB_NAME
# Name of the Summary tab in the collection spreadsheet.
# Example:
SUMMARY_TAB_NAME="Summary"

# SUMMARY_FOLDER_NAME
# Name of the Summary subfolder under the DJ Sets folder (e.g. where “{Year} Summary” sheets live).
# Example:
SUMMARY_FOLDER_NAME="Summary"

# ALLOWED_HEADERS
# List of column names (from set sheets) to include in summary sheets.
# Example:
ALLOWED_HEADERS='["Title", "Artist", "Length", "BPM", "Genre", "Year", "Comment"]'

# desiredOrder
# Order of columns in summary sheets (subset of allowed headers).
# Example:
desiredOrder='["Title", "Artist", "Length", "BPM", "Genre", "Year", "Comment"]'

# DEEJAY_SET_COLLECTION_JSON_PATH
# File path where the DJ set collection JSON snapshot is written.
# Default in code: `v1/deejay-sets/deejay_set_collection.json`
DEEJAY_SET_COLLECTION_JSON_PATH="v1/deejay-sets/deejay_set_collection.json"

# KAIANO_API_REPO_TOKEN (GitHub Actions only)
# GitHub secret used by `update_dj_set_collection` workflow to clone and push the `kaiano-api` repo
# when copying the JSON snapshot. Not used by Python scripts directly.
KAIANO_API_REPO_TOKEN=YOUR_GITHUB_SECRET_TOKEN

# KAIANO_API_BASE_URL
# Base URL for the api-kaianolevine-com instance.
# Example:
KAIANO_API_BASE_URL=https://your-api.railway.app

# KAIANO_API_OWNER_ID
# Owner ID sent with API requests. Falls back to OWNER_ID if not set.
# Example:
KAIANO_API_OWNER_ID=your-owner-id

# OWNER_ID
# Fallback owner ID if KAIANO_API_OWNER_ID is not set.
OWNER_ID=your-owner-id

# Prefect
PREFECT_API_KEY=your-prefect-api-key
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/<account-id>/workspaces/<workspace-id>
PREFECT_ACCOUNT_SLUG=your-account-slug
PREFECT_WORKSPACE_SLUG=your-workspace-slug

# Sentry DSN for error tracking
SENTRY_DSN=your-sentry-dsn

# Spotify
SPOTIPY_CLIENT_ID=your-spotipy-client-id
SPOTIPY_CLIENT_SECRET=your-spotipy-client-secret
SPOTIPY_REFRESH_TOKEN=your-spotipy-refresh-token
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_RADIO_PLAYLIST_ID=your-spotify-radio-playlist-id
